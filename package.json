{
  "name": "ts-doctor-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pproenca/ts-doctor.git"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen": "turbo run gen",
    "gen:check": "turbo run gen:check",
    "check": "pnpm gen:check && pnpm typecheck && pnpm test",
    "release": "pnpm build && pnpm -r publish --no-git-checks"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
