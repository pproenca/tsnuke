{
  "name": "@ts-doctor/api",
  "version": "0.1.0",
  "description": "Programmatic API for ts-doctor — a thin re-export of core's diagnose() boundary.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pproenca/ts-doctor.git",
    "directory": "packages/api"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ts-doctor/core": "workspace:*",
    "@ts-doctor/rules": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0"
  }
}
