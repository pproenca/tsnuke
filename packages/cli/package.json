{
  "name": "tsnuke",
  "version": "0.1.0",
  "description": "A code-health linter and 0–100 scorer for TypeScript projects — a two-tier engine (syntactic + type-aware) over the in-process TypeScript compiler, with config and module-graph rules, an anti-slop family for LLM-generated code, and a local deterministic score. Runs offline via npx.",
  "license": "MIT",
  "author": "Pedro Proença",
  "homepage": "https://github.com/pproenca/tsnuke#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pproenca/tsnuke.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/pproenca/tsnuke/issues"
  },
  "keywords": [
    "typescript",
    "linter",
    "lint",
    "code-health",
    "score",
    "type-aware",
    "static-analysis",
    "effect",
    "mcp",
    "ai",
    "cli"
  ],
  "type": "module",
  "bin": {
    "tsnuke": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "node build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "typescript": "^5.8.0"
  },
  "devDependencies": {
    "@effect/cli": "^0.75.1",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/printer": "^0.49.0",
    "@effect/printer-ansi": "^0.49.0",
    "@effect/vitest": "^0.29.0",
    "@tsnuke/build-report-effect": "workspace:*",
    "@tsnuke/contracts-effect": "workspace:*",
    "@tsnuke/engine-effect": "workspace:*",
    "@tsnuke/exit-code-effect": "workspace:*",
    "@tsnuke/fix-applier-effect": "workspace:*",
    "@tsnuke/format-effect": "workspace:*",
    "@tsnuke/rules-registry-effect": "workspace:*",
    "@types/node": "^22.10.0",
    "effect": "^3.21.2",
    "esbuild": "0.27.7",
    "vitest": "^3.2.0"
  }
}
