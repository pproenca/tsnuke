{
  "name": "@ts-doctor/core",
  "version": "0.1.0",
  "description": "ts-doctor diagnostic core: project discovery, the two-tier engine, local scoring, and the security services.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pproenca/ts-doctor.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": { "@ts-doctor/rules": "workspace:*", "typescript": "^5.8.0" },
  "devDependencies": { "@types/node": "^22.10.0" }
}
