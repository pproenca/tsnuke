{
  "name": "@ts-doctor/mcp",
  "version": "0.1.0",
  "description": "MCP server (stdio) exposing ts-doctor to coding agents: diagnose, explain, list_rules.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pproenca/ts-doctor.git",
    "directory": "packages/mcp"
  },
  "type": "module",
  "bin": { "ts-doctor-mcp": "./dist/server.js" },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "typescript": "^5.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@ts-doctor/core": "workspace:*",
    "@ts-doctor/rules": "workspace:*",
    "@types/node": "^22.10.0"
  }
}
