{
  "name": "@ts-doctor/rules",
  "version": "0.1.0",
  "description": "ts-doctor's TypeScript code-health rule catalog and capability-gated activation engine.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pproenca/ts-doctor.git",
    "directory": "packages/ts-doctor-rules"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "gen": "node scripts/generate-rule-registry.mjs",
    "gen:check": "node scripts/generate-rule-registry.mjs --check"
  },
  "dependencies": { "typescript": "^5.8.0" },
  "devDependencies": { "@types/node": "^22.10.0" }
}
