{
  "name": "ts-doctor",
  "version": "0.1.0",
  "description": "A code-health linter and 0–100 scorer for TypeScript projects. Two-tier engine (syntactic + type-aware), local deterministic scoring, agent-native output.",
  "keywords": [
    "typescript",
    "lint",
    "linter",
    "code-quality",
    "static-analysis",
    "type-safety",
    "ai",
    "agent",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pproenca/ts-doctor.git",
    "directory": "packages/ts-doctor"
  },
  "type": "module",
  "bin": { "ts-doctor": "./dist/cli.js" },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "files": ["dist"],
  "engines": { "node": ">=22" },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "typescript": "^5.8.0"
  },
  "devDependencies": {
    "@ts-doctor/core": "workspace:*",
    "@ts-doctor/rules": "workspace:*",
    "@types/node": "^22.10.0"
  }
}
